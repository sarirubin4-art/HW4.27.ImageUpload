@using HW4._27.ImageUpload.Web.Models;
@model ImageViewModel;


<div class="card mb-3">
	<div class="card-body">
		<h5 class="card-title">@Model.Image.Title</h5>
		<p class="card-subtitle likes">
		</p>
		<p class="card-text"><small class="text-body-secondary">Posted on @Model.Image.DateSubmitted.ToLongDateString() at @Model.Image.DateSubmitted.ToShortTimeString()</small></p>
		<img src="/images/@Model.Image.ImagePath" class="img-fluid img-thumbnail">

	</div>
</div>

@section Scripts {
	<script src="/js/images.js"></script>
}